{
  "name": "cue-gui",
  "version": "0.1.0",
  "description": "Cue — open-source meeting assistant overlay. Cluely-class UI, your model, your data.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "homepage": "https://cue.valthrax.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Suryanandx/cue.git"
  },
  "license": "Apache-2.0",
  "build": {
    "appId": "com.valthrax.cue",
    "productName": "Cue",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "extract-helpers.js",
      "kb-engine.js",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "../cue/agents/builtins", "to": "agents-builtins" }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Suryanandx",
        "repo": "cue"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Cue uses screen and audio capture when you start listening so it can process meeting or system sound. Allow Screen Recording in System Settings if prompted.",
        "NSMicrophoneUsageDescription": "Cue listens to your microphone when you start a session so it can transcribe and respond.",
        "LSUIElement": false
      },
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Cue ${version}",
      "icon": "build/icon.icns",
      "iconSize": 128,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cue"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb",      "arch": ["x64"] }
      ]
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "vectra": "^0.14.0",
    "xlsx": "^0.18.5"
  }
}
